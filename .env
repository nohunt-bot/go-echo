# Server
PORT=8080
APP_ENV=development
REQUEST_TIMEOUT=30s
SHUTDOWN_TIMEOUT=30s
MAX_CONCURRENT=100
RATE_LIMIT_PER_SEC=20

# Redis — single address for host dev; use comma-separated for in-Docker cluster mode
# REDIS_ADDRS=redis-1:6379,redis-2:6379,redis-3:6379
REDIS_ADDRS=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_POOL_TIMEOUT=4s
REDIS_CONN_MAX_IDLE_TIME=5m
REDIS_CONN_MAX_LIFETIME=1h

# Cassandra
CASSANDRA_HOSTS=127.0.0.1
CASSANDRA_KEYSPACE=go_echo
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=
CASSANDRA_NUM_CONNS=2